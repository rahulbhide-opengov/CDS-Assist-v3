#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────
#  CDS-Assist Quick Setup
#  Just run:  ./setup
# ─────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$SCRIPT_DIR"

# Colors
G='\033[0;32m' Y='\033[1;33m' B='\033[0;34m' R='\033[0;31m' BOLD='\033[1m' NC='\033[0m'
ok()   { echo -e "${G}✓${NC} $1"; }
warn() { echo -e "${Y}!${NC} $1"; }
info() { echo -e "${B}→${NC} $1"; }
err()  { echo -e "${R}✗${NC} $1"; }

echo ""
echo -e "${BOLD}  CDS-Assist Setup${NC}"
echo -e "  ─────────────────"
echo ""

# ── 1. Check Node.js ──────────────────────────────────────
if ! command -v node &>/dev/null; then
  err "Node.js is required but not found."
  echo "  Install: https://nodejs.org (LTS recommended)"
  exit 1
fi
NODE_V=$(node -v | sed 's/v//' | cut -d. -f1)
if [ "$NODE_V" -lt 18 ]; then
  err "Node.js 18+ required. You have $(node -v)."
  exit 1
fi
ok "Node.js $(node -v)"

# ── 2. Ask for Figma token (optional) ─────────────────────
echo ""
echo -e "  ${BOLD}Figma Access Token${NC} (needed for design creation)"
echo "  Get one at: https://help.figma.com/hc/en-us/articles/8085703771159"
echo "  Press Enter to skip (you can add it later)."
echo ""
read -rp "  Token: " FIGMA_TOKEN
FIGMA_TOKEN="${FIGMA_TOKEN:-}"

if [[ -n "$FIGMA_TOKEN" && "$FIGMA_TOKEN" != figd_* ]]; then
  warn "Token should start with 'figd_'. Continuing anyway."
fi
echo ""

# ── 3. Auto-detect platform and install ────────────────────
INSTALLED=false

# ── Cursor ─────────────────────────────────────────────────
if [ -d "$HOME/.cursor" ]; then
  info "Detected Cursor IDE — installing..."

  mkdir -p "$HOME/.cursor/skills" "$HOME/.cursor/rules"

  # Symlink skill
  [ -L "$HOME/.cursor/skills/cds-assist" ] && rm "$HOME/.cursor/skills/cds-assist"
  [ -d "$HOME/.cursor/skills/cds-assist" ] && mv "$HOME/.cursor/skills/cds-assist" "$HOME/.cursor/skills/cds-assist.bak"
  ln -s "$REPO_DIR" "$HOME/.cursor/skills/cds-assist"
  ok "Skill linked → ~/.cursor/skills/cds-assist"

  # Install rule (substitute path)
  sed "s|__CDS_ASSIST_HOME__|$REPO_DIR|g" "$REPO_DIR/rules/cds-assist.mdc" \
    > "$HOME/.cursor/rules/cds-assist.mdc"
  ok "Rule installed → ~/.cursor/rules/cds-assist.mdc"

  # Configure Figma MCP
  if [ -n "$FIGMA_TOKEN" ]; then
    MCP_FILE="$HOME/.cursor/mcp.json"
    if [ -f "$MCP_FILE" ] && grep -q '"figma-console"' "$MCP_FILE" 2>/dev/null; then
      ok "Figma MCP already configured"
    else
      node -e "
        const fs = require('fs');
        let config = {};
        try { config = JSON.parse(fs.readFileSync('$MCP_FILE', 'utf8')); } catch {}
        if (!config.mcpServers) config.mcpServers = {};
        config.mcpServers['figma-console'] = {
          command: 'npx',
          args: ['-y', 'figma-console-mcp@latest'],
          env: { FIGMA_ACCESS_TOKEN: '$FIGMA_TOKEN', ENABLE_MCP_APPS: 'true' }
        };
        fs.writeFileSync('$MCP_FILE', JSON.stringify(config, null, 2) + '\n');
      "
      ok "Figma MCP added to ~/.cursor/mcp.json"
    fi
  fi

  INSTALLED=true
fi

# ── Claude Code ────────────────────────────────────────────
if command -v claude &>/dev/null; then
  info "Detected Claude Code — installing..."

  mkdir -p "$HOME/.claude/skills"

  [ -L "$HOME/.claude/skills/cds-assist" ] && rm "$HOME/.claude/skills/cds-assist"
  [ -d "$HOME/.claude/skills/cds-assist" ] && mv "$HOME/.claude/skills/cds-assist" "$HOME/.claude/skills/cds-assist.bak"
  ln -s "$REPO_DIR" "$HOME/.claude/skills/cds-assist"
  ok "Skill linked → ~/.claude/skills/cds-assist"

  if [ -n "$FIGMA_TOKEN" ]; then
    claude mcp add figma-console -s user \
      -e FIGMA_ACCESS_TOKEN="$FIGMA_TOKEN" \
      -e ENABLE_MCP_APPS=true \
      -- npx -y figma-console-mcp@latest 2>/dev/null \
      && ok "Figma MCP added to Claude Code" \
      || warn "Could not add MCP via CLI — add manually later"
  fi

  INSTALLED=true
fi

if ! $INSTALLED; then
  err "No supported IDE found (Cursor or Claude Code)."
  echo "  Install Cursor: https://cursor.com"
  exit 1
fi

# ── 4. Create config directories ───────────────────────────
mkdir -p "$REPO_DIR/config" "$REPO_DIR/.figma-cache"
[ ! -f "$REPO_DIR/config/figma.sources.json" ] && echo '{"version":1,"sources":[]}' > "$REPO_DIR/config/figma.sources.json"

# ── 5. Copy Figma Desktop Bridge plugin ────────────────────
if [ -n "$FIGMA_TOKEN" ]; then
  info "Setting up Figma Desktop Bridge plugin..."
  BRIDGE_SRC=$(find "$HOME/.npm/_npx" -path "*/figma-console-mcp/figma-desktop-bridge" -type d 2>/dev/null | head -1)
  if [ -z "$BRIDGE_SRC" ]; then
    npx -y figma-console-mcp@latest --help >/dev/null 2>&1 || true
    BRIDGE_SRC=$(find "$HOME/.npm/_npx" -path "*/figma-console-mcp/figma-desktop-bridge" -type d 2>/dev/null | head -1)
  fi
  if [ -n "$BRIDGE_SRC" ]; then
    rm -rf "$REPO_DIR/figma-plugin"
    cp -r "$BRIDGE_SRC" "$REPO_DIR/figma-plugin"
    ok "Figma plugin ready at figma-plugin/"
  else
    warn "Could not locate Desktop Bridge plugin (will be available after first MCP use)"
  fi
fi

# ── Done ───────────────────────────────────────────────────
echo ""
echo -e "${BOLD}  ✅ Setup complete!${NC}"
echo ""
echo "  Next steps:"
echo ""
if [ -n "$FIGMA_TOKEN" ]; then
  echo "  1. Open Figma Desktop"
  echo "  2. Go to Plugins → Development → Import plugin from manifest"
  echo -e "     Select: ${G}$(pwd)/figma-plugin/manifest.json${NC}"
  echo "  3. In your Figma file, run: Plugins → Development → Figma Desktop Bridge"
  echo "  4. Restart Cursor, then ask:"
else
  echo "  1. Restart Cursor (or Claude Code), then ask:"
fi
echo ""
echo -e "     ${BOLD}@cds-assist design a user profile page${NC}"
echo ""
echo "  To update later:  git pull"
echo "  To uninstall:     bash scripts/install.sh --uninstall"
echo ""
