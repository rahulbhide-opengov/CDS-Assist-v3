# CDS-Assist GitHub Integration
# Copy this file to .env.local and fill in your values

# GitHub Personal Access Token (required for live branch/PR data)
# Create at: https://github.com/settings/tokens
# Scopes needed: repo (read), pull requests (read)
VITE_GITHUB_TOKEN=ghp_your_token_here

# GitHub repository details
VITE_GITHUB_OWNER=OpenGov
VITE_GITHUB_REPO=cds-assists

# Set to 'true' to use mock data instead of live GitHub API
VITE_USE_MOCK_GITHUB=false
