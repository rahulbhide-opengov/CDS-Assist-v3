{
  "name": "seamstress-design",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered rapid prototyping system for OpenGov designers using Capital Design System",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenGov/cds-assists.git",
    "directory": "seamstress-design"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc -b && vite build",
    "build:prod": "vite build --mode production",
    "build:analyze": "vite build --mode production && vite-bundle-visualizer",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "./scripts/cleanup.sh",
    "clean:cache": "rm -rf .vite node_modules/.vite",
    "clean:all": "npm run clean && rm -rf node_modules package-lock.json",
    "reinstall": "npm run clean:all && npm install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test-storybook": "test-storybook",
    "coverage": "vitest run --coverage",
    "chromatic": "chromatic --exit-zero-on-changes",
    "chromatic:ci": "chromatic --exit-zero-on-changes --exit-once-uploaded",
    "deploy:storybook": "npm run build-storybook && npm run chromatic",
    "sync:figma": "node scripts/sync-figma-variables.js",
    "validate:tokens": "node scripts/validate-design-tokens.cjs",
    "validate:design-tokens": "node scripts/validate-design-tokens.cjs",
    "validate:design-tokens:fix": "node scripts/validate-design-tokens.cjs --fix",
    "validate:design-tokens:strict": "node scripts/validate-design-tokens.cjs --strict",
    "figma:connect": "figma connect publish --token $FIGMA_ACCESS_TOKEN",
    "figma:connect:parse": "figma connect parse",
    "audit": "npm run lint && npm run validate:design-tokens",
    "audit:strict": "npm run lint && npm run validate:design-tokens:strict",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --no-error-on-unmatched-pattern",
      "node scripts/validate-design-tokens.cjs"
    ]
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@mui/icons-material": "^7.3.1",
    "@mui/lab": "^7.0.0-beta.16",
    "@mui/material": "^7.3.1",
    "@mui/system": "^7.3.2",
    "@mui/x-data-grid": "^8.11.2",
    "@mui/x-date-pickers": "^8.25.0",
    "@mui/x-date-pickers-pro": "^8.27.0",
    "@octokit/rest": "^22.0.1",
    "@opengov/capital-mui-theme": "^37.13.0",
    "@opengov/components-ai-patterns": "^37.8.1",
    "@opengov/components-drawer": "^37.0.0-beta.6",
    "@opengov/components-file-management": "^37.1.2",
    "@opengov/components-modal": "^37.0.0-beta.1",
    "@opengov/components-nav-bar": "^37.13.1",
    "@opengov/components-page-header": "^37.6.0",
    "@opengov/components-pagination": "^37.0.4",
    "@opengov/components-result": "^37.0.5",
    "@opengov/react-capital-assets": "^37.15.0",
    "@tanstack/react-query": "^5.90.19",
    "@tiptap/core": "^3.4.4",
    "@tiptap/extension-heading": "^3.4.4",
    "@tiptap/extension-link": "^3.4.4",
    "@tiptap/extension-placeholder": "^3.4.4",
    "@tiptap/extension-text-align": "^3.4.4",
    "@tiptap/extension-typography": "^3.4.4",
    "@tiptap/pm": "^3.4.4",
    "@tiptap/react": "^3.4.4",
    "@tiptap/starter-kit": "^3.4.4",
    "@tiptap/suggestion": "^3.4.4",
    "@types/react-resizable": "^3.0.8",
    "@types/turndown": "^5.0.5",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "dompurify": "^3.2.7",
    "framer-motion": "^12.23.24",
    "highcharts": "^12.5.0",
    "highcharts-react-official": "^3.2.3",
    "leaflet": "^1.9.4",
    "marked": "^16.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.5.0",
    "react-hook-form": "^7.71.1",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable": "^3.1.3",
    "react-router-dom": "^6.30.1",
    "react-use": "^17.6.0",
    "recharts": "^3.2.1",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.1",
    "vis-data": "^8.0.3",
    "vis-network": "^10.0.2",
    "vite-plugin-svgr": "^4.5.0",
    "yup": "^1.7.1",
    "zustand": "^5.0.8"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/js": "^9.33.0",
    "@faker-js/faker": "^10.0.0",
    "@figma/code-connect": "^1.3.7",
    "@storybook/addon-a11y": "^9.1.3",
    "@storybook/addon-docs": "^9.1.3",
    "@storybook/addon-onboarding": "^9.1.3",
    "@storybook/addon-themes": "^9.1.3",
    "@storybook/addon-vitest": "^9.1.3",
    "@storybook/react-vite": "^9.1.3",
    "@storybook/test-runner": "^0.23.0",
    "@storybook/testing-library": "^0.2.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "chromatic": "^13.1.4",
    "eslint": "^9.33.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^9.1.3",
    "fake-indexeddb": "^6.2.2",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.55.0",
    "puppeteer": "^24.21.0",
    "storybook": "^9.1.3",
    "terser": "^5.44.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-plugin-circular-dependency": "^0.5.0",
    "vitest": "^3.2.4"
  }
}
